[url "git@github.com:"]
  insteadOf = https://github.com/
[color]
	ui = true
  diff = true
[mergetool "diffmerge"]
  cmd = diffmerge --merge --result=\"`pwd`/$MERGED\" \"`pwd`/$LOCAL\" \"`pwd`/$BASE\" \"`pwd`/$REMOTE\"
	trustExitCode = false
[mergetool "nvimdiff"]
  conflictstyle = diff3
[mergetool "diffview"]
  cmd = nvim -f -n -c "DiffviewOpen" "$MERGE"
[mergetool]
  keepBackup = false
  prompt = false
[diff]
  #tool = diffmerge
  tool = nvimdiff
  algorithm = histogram
[merge]
  #tool = diffmerge
  tool = diffview
  conflictStyle = zdiff3
[core]
  autocrlf = false
  safecrlf = false
  pager = delta
[interactive]
  diffFilter = delta --color-only
[alias]
  s = status
  co = checkout
  cam = commit -am
[rerere]
	enabled = true
[fetch]
	prune = true
[pull]
	rebase = true
[rebase]
	autoStash = true
[push]
	default = current
	autoSetupRemote = true
[user]
  email = "craig@theisraels.net"
	name = Craig Israel
[pager]
  branch = false
# Add local overrides to one of the following files
# For example, user.email
[include]
  path = ~/.gitconfig.local

[url "git@github.com:"]
	insteadOf = https://github.com

[branch]
	sort = -committerdate
[init]
	defaultBranch = main
